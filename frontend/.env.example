# Copy to .env.local before `npm run dev`.
# Get keys from https://dashboard.clerk.com — create a new application.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Where the control plane lives. Match what `./scripts/local_dev.sh serve` prints.
NEXT_PUBLIC_DEVFORGE_API=http://localhost:8001

# DEMO-GRADE ONLY: this token is exposed to the browser via NEXT_PUBLIC_*.
# Anyone with DevTools sees it. Production must move admin-token-gated calls
# to a server-side Next.js API route.
NEXT_PUBLIC_DEVFORGE_ADMIN_TOKEN=devforge-local-admin-only-do-not-share
