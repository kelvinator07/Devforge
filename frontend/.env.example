# Copy to .env.local before `npm run dev`.
# Get Clerk keys from https://dashboard.clerk.com — create a new application.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Where the control plane lives. Match what `./scripts/local_dev.sh serve` prints.
NEXT_PUBLIC_DEVFORGE_API=http://localhost:8001

# Optional — enables the "view trace ↗" button on /jobs/[id]. Find your project
# id by opening any trace on cloud.langfuse.com — the URL is
# /project/<this>/traces/<trace_id>.
NEXT_PUBLIC_LANGFUSE_PROJECT_ID=
NEXT_PUBLIC_LANGFUSE_HOST=https://cloud.langfuse.com

# After #B2 the admin token is no longer shipped to the browser. Approve+run
# is authorized via the user's Clerk JWT (mapped to a tenant via
# tenants.clerk_user_id / clerk_org_id). Backfill the mapping once with:
#   uv run python -m scripts.link_tenant_clerk_identity <tenant_id> --user user_…
