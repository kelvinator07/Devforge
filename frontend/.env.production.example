# Copy to .env.production (gitignored) before `npm run build` for AWS deploys.
# These NEXT_PUBLIC_* values are baked into the static export — anyone who
# downloads the bundle can read them, so keep them production-grade keys (no
# admin secrets here, see .env.example for why).

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Production control plane — pull this from `terraform/7_control_plane`'s
# API Gateway / Lambda Function URL output.
NEXT_PUBLIC_DEVFORGE_API=https://api.devforge.example.com

NEXT_PUBLIC_LANGFUSE_PROJECT_ID=
NEXT_PUBLIC_LANGFUSE_HOST=https://cloud.langfuse.com

# AWS API Gateway HTTP API buffers Lambda responses → SSE non-starter.
# Set to 1 to make the job-detail page poll GET /jobs/{id}?since_event_id=N
# every 1.5s instead. Leave unset for local Docker (uvicorn streams natively).
NEXT_PUBLIC_DEVFORGE_USE_POLLING=1
